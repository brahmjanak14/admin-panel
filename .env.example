# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shyaam_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Cache TTL (seconds)
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf

# App
APP_NAME=Shyaam Admin API
PUBLIC_SITE_URL=https://shyaam.in

# Seed (dev only)
SEED_ADMIN_EMAIL=admin@shyaam.in
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Super Admin

# Google Sheets (optional — Contact + Consultation form sync)
# 1. Create a Google Cloud service account and download the JSON key
# 2. Create a spreadsheet with two tabs named "Contact" and "Consultation"
# 3. Share the spreadsheet with the service account email (Editor)
# 4. Set GOOGLE_SHEETS_ENABLED=true and fill credentials below
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-from-url
GOOGLE_SHEETS_CONTACT_TAB=Contact
GOOGLE_SHEETS_CONSULTATION_TAB=Consultation
